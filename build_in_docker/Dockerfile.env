ARG TARGETARCH
ARG CUDA_VERSION=13.0.2
ARG UBUNTU_VERSION=24.04
FROM nvidia/cuda:${CUDA_VERSION}-devel-ubuntu${UBUNTU_VERSION}

ARG DEBIAN_FRONTEND=noninteractive
ARG GCC_VERSION=13
ARG CMAKE_VERSION=3.29.6
ARG MINIFORGE_VERSION=24.7.1-0
ARG TARGETARCH
ARG CONDA_ENV_NAME=cugraph
ARG CONDA_ENV_FILE=
ARG CCACHE_DIR=/ccache
ARG CCACHE_BASEDIR=/cugraph
ARG CCACHE_MAXSIZE=20G

SHELL ["/bin/bash", "-lc"]

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    gnupg2 \
    lsb-release \
    wget \
    python3 \
    python3-pip \
    build-essential \
    ccache \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# GCC/G++ 13.x (Ubuntu 24.04 default toolchain)
RUN apt-get update \
    && apt-get install -y --no-install-recommends gcc-${GCC_VERSION} g++-${GCC_VERSION} \
    && update-alternatives --install /usr/bin/gcc gcc /usr/bin/gcc-${GCC_VERSION} 100 \
       --slave /usr/bin/g++ g++ /usr/bin/g++-${GCC_VERSION} \
    && rm -rf /var/lib/apt/lists/*

# CMake 3.29.6+ (prefer newer than Ubuntu 24.04 repo)
RUN python3 -m pip install --no-cache-dir --break-system-packages "cmake==${CMAKE_VERSION}"

# Miniforge (conda) for RAPIDS env management
RUN case "${TARGETARCH}" in \
      "amd64"|"") ARCH="x86_64" ;; \
      "arm64") ARCH="aarch64" ;; \
      *) echo "Unsupported TARGETARCH: ${TARGETARCH}" ; exit 1 ;; \
    esac \
    && curl -fsSL -o /tmp/miniforge.sh \
      "https://github.com/conda-forge/miniforge/releases/download/${MINIFORGE_VERSION}/Miniforge3-${MINIFORGE_VERSION}-Linux-${ARCH}.sh" \
    && bash /tmp/miniforge.sh -b -p /opt/conda \
    && rm -f /tmp/miniforge.sh \
    && /opt/conda/bin/conda config --set channel_priority strict \
    && /opt/conda/bin/conda clean -a -y

ENV PATH=/opt/conda/bin:/usr/local/cuda/bin:/usr/local/bin:${PATH}
ENV LD_LIBRARY_PATH=/usr/local/cuda/lib64:${LD_LIBRARY_PATH}
ENV CC=/usr/bin/gcc-${GCC_VERSION}
ENV CXX=/usr/bin/g++-${GCC_VERSION}
ENV CUDAHOSTCXX=/usr/bin/g++-${GCC_VERSION}
ENV CCACHE_DIR=${CCACHE_DIR}
ENV CCACHE_BASEDIR=${CCACHE_BASEDIR}
ENV CCACHE_MAXSIZE=${CCACHE_MAXSIZE}

# Create the conda environment
COPY conda/environments /tmp/conda/environments
RUN if [[ -n "${CONDA_ENV_FILE}" ]]; then \
        ENV_FILE="${CONDA_ENV_FILE}"; \
    else \
        case "${TARGETARCH}" in \
            "arm64") ENV_FILE="/tmp/conda/environments/all_cuda-131_arch-aarch64.yaml" ;; \
            "amd64"|"") ENV_FILE="/tmp/conda/environments/all_cuda-131_arch-x86_64.yaml" ;; \
            *) echo "Unsupported TARGETARCH: ${TARGETARCH}" ; exit 1 ;; \
        esac; \
    fi \
    && case "${TARGETARCH}" in \
        "arm64") CONDA_SUBDIR="linux-aarch64" ;; \
        "amd64"|"") CONDA_SUBDIR="linux-64" ;; \
        *) echo "Unsupported TARGETARCH: ${TARGETARCH}" ; exit 1 ;; \
    esac \
    && /opt/conda/bin/conda config --set subdir "${CONDA_SUBDIR}" \
    && /opt/conda/bin/conda env create -n ${CONDA_ENV_NAME} -f "${ENV_FILE}" \
    && /opt/conda/bin/conda clean -a -y

WORKDIR /cugraph
RUN mkdir -p /opt/cugraph
RUN mkdir -p ${CCACHE_DIR}

# Build helper scripts.
COPY build_in_docker/docker_build_cugraph.sh /opt/cugraph/build.sh
COPY build_in_docker/conda_env.sh /opt/cugraph/conda_env.sh
COPY build_in_docker/build_libcuvs_sm89.sh /opt/cugraph/build_libcuvs_sm89.sh
RUN chmod +x /opt/cugraph/build.sh /opt/cugraph/conda_env.sh /opt/cugraph/build_libcuvs_sm89.sh
